classDiagram
    Owner <.. Scheduler
    Pet <.. Scheduler
    Task <.. Scheduler
    Priority <.. Task
    Task <.. Pet

    class Owner{
        +String name
        +int available_minutes
        +int day_start_hour
        +list pets
        +add_pet()
        +all_tasks()
    }
    class Pet{
        +String name
        +String species
        +String breed
        +float age_years
        +list tasks
        +add_task()
    }
    class Task{
        +String name
        +int duration_minutes
        +Priority priority
        +String category
        +String notes
        +String time
        +String frequency
        +bool completed
        +int repeat_day
        +mark_complete()
        +is_due_today()
    }
    class Scheduler{
        +Owner owner
        +add_task(task, pet)
        +remove_task(name, pet)
        +generate_plan()
        +explain()
        +tasks_by_category()
        +is_overbooked()
        +conflicts()
        +_all_tasks()
    }
    class Priority{
        HIGH
        MEDIUM
        LOW
        +order()
    }